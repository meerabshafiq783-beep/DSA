#include <iostream>
using namespace std;
void selectionsort(int input[],int n){
  for(int i=0;i<n-1;i++)
{ 
    int minindex=i;
    for(int j=i+1;j<n;j++)
    {
        if(input[j]<input[minindex])//for descendind use greater than symbol
        {
            minindex=j;
        }}
         swap(input[i],input[minindex]);
}}
int main() 
{   
    int n;
    cout<<"enter size of an array:"<<endl;
    cin>>n;
    int input[n];
    cout<<"enter "<< n <<" elements:"<<endl;
    for(int i=0;i<n;i++)
    {
        cin>>input[i];}
    
    selectionsort(input,n);
   cout<<"sorted array through selection sort"<<endl;
        for(int i=0;i<n;i++)
{
    cout<<input[i]<<" ";
}
   return 0; 
    
}
