#include <iostream>
using namespace std;
void insertionsort(int input[],int n){
  for(int i=1;i<n;i++)
{ int curr=input[i];
  int prev=i-1;
    while(prev>=0 && input[prev]>curr)
    {
        input[prev+1]=input[prev];
        prev--;
    }
        input[prev+1]=curr;
}}
int main() 
{   
    int n;
    cout<<"enter size of an array:"<<endl;
    cin>>n;
    int input[n];
    cout<<"enter "<< n <<" elements:"<<endl;
    for(int i=0;i<n;i++)
    {
        cin>>input[i];}
   
    insertionsort(input,n);
   cout<<"sorted array through insertion sort"<<endl;
        for(int i=0;i<n;i++)
{
    cout<<input[i]<<" ";
}
   return 0; 
    
}
